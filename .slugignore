# ═══════════════════════════════════════════════════════════════════════════
# Files & directories to EXCLUDE from the Heroku slug.
# ═══════════════════════════════════════════════════════════════════════════

# Large binary / design assets (not served, only used as page icon — we
# use a tiny favicon.ico instead)
*.png
*.jpg
*.jpeg
*.gif
*.ico
*.psd
*.ai
*.svg

# Archives
*.zip
*.tar.gz
*.tgz
*.bz2
*.rar

# Python bytecode & build artifacts
__pycache__
*.pyc
*.pyo
*.egg-info
*.egg
dist/
build/
*.whl

# Version control
.git
.gitignore
.gitattributes

# Test & development
tests/
.pytest_cache/
.coverage
*.coverage
htmlcov/

# IDE / Editor
.idea/
.vscode/
*.swp
*.swo

# Documentation
docs/
README.md

# OpenCode configuration
opencode.jsonc

# Environment files (never ship secrets)
.env
.env.*
